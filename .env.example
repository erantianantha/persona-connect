# ── LLM ──────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── RAG / Vector DB ───────────────────────────────────────────────────────────
# Get from: https://app.pinecone.io/  → Create index named "persona", 384 dims, cosine
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=persona
PINECONE_ENVIRONMENT=us-east-1

# ── Voice Agent (Vapi) ────────────────────────────────────────────────────────
# Get from: https://app.vapi.ai/  → Account → API Keys
VAPI_API_KEY=your_vapi_api_key_here
# Get from: https://app.vapi.ai/  → Account → API Keys → Public Key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here
# Create your assistant at https://app.vapi.ai/ and paste its ID here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# ── Text-to-Speech (ElevenLabs) ───────────────────────────────────────────────
# Get from: https://elevenlabs.io/  → API Keys
# Default voice ID below is "Adam" (stock, no clone needed)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Calendar (Cal.com) ────────────────────────────────────────────────────────
# Get from: https://app.cal.com/  → Settings → API Keys
# EVENT_TYPE_ID: go to your event type URL, it's the number in the path
CAL_API_KEY=your_cal_api_key_here
CAL_EVENT_TYPE_ID=your_cal_event_type_id_here

# ── GitHub ingestion ──────────────────────────────────────────────────────────
# Get from: https://github.com/settings/tokens → "repo" + "read:user" scopes
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=erantianantha

# ── Service URLs (cross-service calls) ────────────────────────────────────────
# Voice backend: set to your Render URL after deploy
# Chat (Next.js) calls this to retrieve RAG chunks
RAG_SERVICE_URL=your_deployed_render_voice_app_url_here
